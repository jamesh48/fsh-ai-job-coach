generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model DailyLog {
  id        String   @id @default(cuid())
  date      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentEmail {
  id             String   @id @default(cuid())
  emailId        String   @unique
  threadId       String
  subject        String
  sender         String
  snippet        String
  date           String
  classification Json
  receivedAt     DateTime @default(now())
}

model AgentCalendarEvent {
  id             String   @id @default(cuid())
  eventId        String   @unique
  summary        String
  description    String?
  start          String?
  end            String?
  organizer      String?
  classification Json
  receivedAt     DateTime @default(now())
}

model Settings {
  id                     String   @id @default("singleton")
  anthropicApiKey        String?
  agentSecret            String?
  passwordHash           String?
  lastRecommendation     String?
  lastRecommendationAt   DateTime?
  careerProfile          String?
  resume                 String?
  jobSearchPlan          String?
  profileLinks           String?
  updatedAt              DateTime @updatedAt
}
